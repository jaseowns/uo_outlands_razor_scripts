        if EnableOverheadMessages = 1
            if insysmsg "Your shot hinders" and not dead ClosestTarget
                overhead "[ HINDERED! ]" 149 ClosestTarget
            endif
        else 
            if insysmsg "Your shot hinders" and not dead ClosestTarget
                overhead "*hindered*" 149 ClosestTarget
            endif            
        endif 
        
        
