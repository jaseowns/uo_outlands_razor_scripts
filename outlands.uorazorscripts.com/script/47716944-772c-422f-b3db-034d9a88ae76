                            overhead '[ WEIGHT LIMIT REACHED! ]' 37
                            settimer "WeightTimer" 0
                        else
                            overhead " Ď " 37
                            settimer "WeightTimer" 0
                        endif

                        if EnableAutoWeightRecall = 1 and not find ClosestTarget ground -1 -1 8 and WILDERNESSMODE = 1
                            wait 1000
                            hotkey 'Toggle Peace Only'
                            @setvar! WarModeToggledWhileFighting 0
                            @setvar! AutoWeightRecall 1
                            replay
                        elseif EnableAutoWeightRecall = 1 and find ClosestTarget ground -1 -1 8 and WILDERNESSMODE = 1
                            if timer "RECALLDELAY" > 3500 and EnableAutoRecallOverheadMessages = 1
                                overhead '[ WAITING TO RECALL... ]' 149
                                settimer "RECALLDELAY" 0
                            endif
                            wait 500
                        elseif EnableAutoWeightDungeonGate = 1 and DUNGEONMODE = 1
                            wait 500
                            hotkey 'Toggle Peace Only'
                            @setvar! WarModeToggledWhileFighting 0
                            @setvar! TimeToGo 1
                            replay
                        else
                            if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                overhead '[ OVERWEIGHT! ]' 337
                            else
                                overhead " „ " 337
                            endif
                            wait 1500
                            overhead '[ STOPPING SCRIPT! ]' 88
                        endif
                    endif
                endif
                
                if not warmode
                    replay
                endif

                if targetexists
                    hotkey 'cancel current target'
                endif
                
                if SkipTimers != 1
                    @setvar! SkipTimers 1
                endif
            endwhile

            ////////////////////////////
            //   END NO TARGET LOOP   //
            ////////////////////////////

            getlabel backpack backpacklabel
        else 
            @setvar! AttackModeActive 0
        endif
    endif

    if not dead ClosestTarget and find ClosestTarget ground -1 -1 TargetAttackRange and AttackModeActive = 1
        // Skip target checks and begin attack loop!

    //////////////////////
    //  TARGET CHECKER  //
    //////////////////////

    elseif not dead TargetToAnalyze and find TargetToAnalyze ground -1 -1 12
        if warmode
            while diffhits < ActivateAutoHealHPdiff and find TargetToAnalyze ground -1 -1 12 and AttackModeActive = 0
                if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                    if timer AnalyzingTargetsTimer > 10000
                        overhead '[ ANALYZING TARGET... ]' 90
                        settimer AnalyzingTargetsTimer 0
                    endif
                endif

                if dead
                    replay
                endif

                if dead TargetToAnalyze or not find TargetToAnalyze ground -1 -1 12
                    @setvar! AttackModeActive 0
                    replay
                endif

                if diffhits > ActivateAutoHealHPdiff
                    replay
                endif

                if insysmsg "world is saving"
                    settimer "WorldSaveTimer" 0
                    if EnableOverheadMessages = 1
                        overhead '[ WORLD SAVING... ]' 253
                    endif
                    while timer "WorldSaveTimer" < 4500
                        if insysmsg "save complete"
                            clearsysmsg
                            break
                        endif
                        wait 100
                    endwhile
                    if EnableOverheadMessages = 1
                        overhead '[ SAVE COMPLETE! ]' 253
                    endif
                endif
                
                if EnableAutoCarving = 1 and findtype 11552 self
                    while findtype "corpse" ground -1 -1 2 as deadbody and diffhits < ActivateAutoHealHPdiff 
                        settimer SkinningTimeoutTimer 0
                        if findtype 11552 self
                            if targetexists
                                hotkey 'cancel current target'
                            endif

                            while not targetexists                    
                                skill 'forensicevaluation'
                                getlabel backpack backpacklabel
                            endwhile

                            clearsysmsg

                            if targetexists and find deadbody ground -1 -1 2
                                target 'self'
                                @ignore deadbody
                                wait 250
                            endif

                            if insysmsg "You dont see anything nearby"
                                clearsysmsg 
                                break
                            else
                                if EnableOverheadMessages = 1 and timer SkinningTimer > 3000 
                                    overhead '[ SKINNING... ]' 333
                                    settimer SkinningTimer 0
                                endif
                                break
                            endif 
                        else 
                            if EnableOverheadMessages = 1 and timer SkinningTimer > 15000
                                overhead '[ NO SKINNING KNIFE ]' 337
                                settimer SkinningTimer 0
                                break
                            endif  
                        endif 

                        if timer SkinningTimeoutTimer > 1500 or diffhits > ActivateAutoHealHPdiff
                            break
                        endif 
                    endwhile
                endif 

                if find TargetToAnalyze ground -1 -1 12
                    getlabel TargetToAnalyze tempLabel

                    while "-" in tempLabel
                        getlabel TargetToAnalyze tempLabel
                    endwhile

                    if inlist animalsIgnoreList tempLabel
                        if timer "IgnoreMOBtimer" > 2500
                            if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                overhead '[ IGNORING MOB! ]' 333 TargetToAnalyze
                            else
                                overhead " Ď " 333 TargetToAnalyze
                            endif
                            getlabel backpack backpacklabel
                            settimer "IgnoreMOBtimer" 0
                            @ignore TargetToAnalyze
                        endif
                    else
                        clearsysmsg 
                        skill 'begging'
                        settimer AntiStallTimer 0
                        wait 250
                        while not targetexists
                            if insysmsg 'you must wait'
                                clearsysmsg 
                                skill 'begging'
                                wait 250
                            endif
                            wait 250
                            if timer AntiStallTimer > 1500
                                settimer AntiStallTimer 0
                                break
                            endif
                        endwhile

                        if targetexists 
                            target TargetToAnalyze
                            getlabel backpack backpacklabel
                        endif

                        if not dead TargetToAnalyze and find TargetToAnalyze ground -1 -1 12
                            if insysmsg "cannot be seen"
                                if EnableOverheadMessages = 1 or EnableOverheadMessages = 2 
                                    if timer "CannotSeeTargetTimer" > 3000 
                                        overhead  '[ CANNOT SEE TARGET! ]' 44
                                        settimer "CannotSeeTargetTimer" 0
                                    endif
                                elseif timer "CannotSeeTargetTimer" > 4500
                                    overhead " Ľ " 44 TargetToAnalyze
                                    settimer "CannotSeeTargetTimer" 0
                                endif

                                if diffhits > ActivateAutoHealHPdiff
                                    replay
                                endif

                                clearsysmsg 
                                hotkey 'target closest grey monster'
                                getlabel backpack backpacklabel
                                @setvar! TargetToCheck lasttarget

                                if insysmsg 'No one matching that' 
                                    @setvar! AttackModeActive 0
                                    @setvar! TargetToAnalyze 0
                                    @setvar! TargetToCheck 0
                                    break
                                elseif TargetToCheck != TargetToAnalyze
                                    @setvar! AttackModeActive 0
                                    @setvar! TargetToAnalyze 0
                                    @setvar! TargetToCheck 0
                                    break
                                elseif find TargetToAnalyze ground -1 -1 TargetAttackRange
                                    @setvar! TargetToAnalyze lasttarget
                                    @setvar! AttackModeActive 2
                                else 
                                    break
                                endif 
                            elseif insysmsg "That is too far away."
                                if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                    if timer "TargetIsTooFarTimer" > 2000
                                        overhead '[ GET CLOSER! ]' 69
                                        overhead " Ľ " 69 TargetToAnalyze
                                        settimer "TargetIsTooFarTimer" 0
                                    endif
                                elseif timer "TargetIsTooFarTimer" > 4500
                                    overhead " Ľ " 44 TargetToAnalyze
                                    settimer "TargetIsTooFarTimer" 0
                                endif                                    
                            elseif insysmsg "Perhaps" or insysmsg "You are too far away from them." or insysmsg "They do not appear to have anything to offer you." or insysmsg "You must wait" or insysmsg "You cannot beg from an individual"
                                if find TargetToAnalyze ground -1 -1 TargetAttackRange
                                    if ClosestTarget != TargetToAnalyze
                                        settimer CurseTimer 60000
                                        settimer ManaDrainTimer 60000
                                        getlabel backpack backpacklabel
                                    endif
                                  
                                    clearsysmsg 
                                    @setvar! ClosestTarget TargetToAnalyze
                                    @setvar! previousTarget ClosestTarget
                                    settimer 'PainSpikeDelayTimer' 0
                                    @setvar! ClosestTargetisSticky 0
                                   
                                    
                                    attack ClosestTarget
                                    
                                    
                                    if timer "AttackTargetTimer" > 15000
                                        if EnableOverheadMessages = 1
                                            overhead '[ ATTACKING! ]' 69
                                        endif
                                        settimer "AttackTargetTimer" 0
                                    endif
                                        
                                    @setvar! AttackModeActive 1
                                    @setvar! NoTargetMode 0
                                    @setvar! TargetSwap 0
                                    @setvar! ClosestTargetisSticky 0
                                    @setvar! RepeatCastingPoison 1
                                    settimer PainSpikeDelayTimer 0
                                    settimer TargetChecker 0
                                     
                                    if EnableNecroCorpseSkin = 1
                                        settimer CorpseSkinDiseaseTimer 0
                                    endif
                                    
                                    if find ClosestTarget ground -1 -1 TargetAttackRange
                                        getlabel ClosestTarget TargetDesc
                                        if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                            if "Paragon" in TargetDesc and find ClosestTarget ground -1 -1 TargetAttackRange
                                                overhead '[ PARAGON! ]' 12 ClosestTarget
                                                overhead " Ľ " 12 ClosestTarget
                                                settimer "TargetTimer" 0
                                            elseif find ClosestTarget ground -1 -1 TargetAttackRange
                                                overhead '[ TARGET ]' 69 ClosestTarget
                                                overhead " Ľ " 69 ClosestTarget
                                                settimer "TargetTimer" 0
                                            endif
                                        else
                                            if "Paragon" in TargetDesc and find ClosestTarget ground -1 -1 TargetAttackRange
                                                overhead " ĽĽĽ " 12 ClosestTarget
                                                settimer "TargetTimer" 0
                                            elseif find ClosestTarget ground -1 -1 TargetAttackRange
                                                overhead " Ľ " 69 ClosestTarget
                                                settimer "TargetTimer" 0
                                            endif
                                        endif
                                    endif
                                    break
                                else
                                    if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                        if timer "TargetIsTooFarTimer" > 3500
                                            overhead '[ GET CLOSER! ]' 69
                                            settimer "TargetIsTooFarTimer" 0
                                        endif
                                    elseif timer "TargetIsTooFarTimer" > 4500
                                        overhead " Ľ " 69 TargetToAnalyze
                                        settimer "TargetIsTooFarTimer" 0
                                    endif
                                endif
                            endif
                        else
                            replay                            
                        endif
                    endif
                else 
                    @setvar! TargetToAnalyze 0
                    replay
                endif
                
                getlabel backpack backpacklabel

                if AttackModeActive != 0
                    break
                endif

                if targetexists
                    hotkey 'cancel current target'
                endif

                if casting
                    interrupt
                endif
            endwhile
        endif
        getlabel backpack backpacklabel
    endif

    
    ////////////////////////
    //       BUFFS:       //
    ////////////////////////

    if dead
        replay
    endif

    if diffhits > ActivateAutoHealHPdiff
        replay
    endif

    @setvar! CastingWasInterrupted 0

    if EnableMagicReflection = 1 and skill 'magery' >= 70 and not findbuff "Magic Reflection" and mana >= MinimumManaToApplyMageryBuffs and diffhits < ActivateAutoHealHPdiff and timer MagicReflectTimer > 15000 and findtype 3972 self and findtype 3974 self and findtype 3981 self
        if targetexists
            hotkey 'cancel current target'
        endif        
        cast 'Magic Reflection'
        while not casting
            wait 250
            if insysmsg "that spell will not" or insysmsg "that spell is already" or insysmsg "You must wait"
                settimer MagicReflectTimer 0
                clearsysmsg 
                break
            endif
            if targetexists
                hotkey 'cancel current target'
            endif
            cast 'Magic Reflection'
        endwhile
        while casting
            if timer MagicReflectTimer < 5000
                break
            endif 
            if diffhits >= ActivateAutoHealHPdiff
                interrupt
                @setvar! AttackModeActive 1
                replay
            endif

            if EnableCurePotion = 1
                while poisoned and casting and not targetexists
                    if findtype "Orange Potion" self
                        dclicktype "Orange Potion"
                        if EnableOverheadMessages = 1 and timer 'OrangePotionMessageTimer' > 3500
                            if insysmsg "potion satchel used"
                                overhead '[ FREE CURE POTION ]' 44
                            else
                                overhead '[ CURE POTION ]' 44
                            endif
                            clearsysmsg
                            settimer 'OrangePotionMessageTimer' 0
                        endif
                        wait 500
                    else
                        if timer 'OrangePotionMessageTimer' > 5000 and EnableOverheadMessages = 1
                            overhead '[ NO CURE POTS! ]' 337
                            settimer 'OrangePotionMessageTimer' 0
                        endif
                        break
                    endif
                endwhile
            endif

            if EnableHealPotion = 1 and diffhits >= HealPotionHPdiff
                if findtype "Yellow Potion" self as HealPot
                    getlabel HealPot HealPotlabel
                    if "next" in HealPotlabel
                        // Do nothing
                    else
                        @setvar! HealPotionCheck 0
                    
                        if counttype 3852 self as HealPotCount
                            @setvar! HealPotionCheck HealPotCount
                        endif
                        clearsysmsg
                        dclicktype 3852
                        getlabel backpack backpackdesc
                        wait 250
                        if insysmsg "potion satchel used"
                            settimer 'HealPotionTimer' 0
                            cooldown "Healing Potion" HealingPotionCooldown
                            if EnableOverheadMessages = 1 and timer 'YellowPotionMessageTimer' > 4500
                                overhead '[ FREE HEAL POTION ]' 253
                            endif
                        elseif HealPotionCheck != counttype 3852 self
                            settimer 'HealPotionTimer' 0
                            cooldown "Healing Potion" HealingPotionCooldown
                            if EnableOverheadMessages = 1 and timer 'YellowPotionMessageTimer' > 4500
                                overhead '[ HEAL POTION ]' 253
                            endif
                        endif
                        clearsysmsg 
                    endif
                else
                    if timer 'YellowPotionMessageTimer' > 4500 and EnableOverheadMessages = 1
                        overhead '[ NO HEAL POTS! ]' 337
                        settimer 'YellowPotionMessageTimer' 0
                    endif
                endif
            endif
        endwhile
        settimer MagicReflectTimer 0
        wait 250
    endif

    if EnableReactiveArmour = 1 and skill 'magery' >= 30 and not findbuff "Reactive Armor" and mana >= MinimumManaToApplyMageryBuffs and diffhits < ActivateAutoHealHPdiff and timer ReactiveArmorTimer > 15000 and findtype 3980 self and findtype 3972 self and findtype 3981 self
        if targetexists 
            hotkey 'cancel current target'
        endif
        cast 'Reactive Armor'
        settimer AntiStallTimer 0
        while not casting and timer AntiStallTimer < 3500
            wait 250 
            if insysmsg "that spell will not" or insysmsg "that spell is already"
                settimer ReactiveArmorTimer 0
                break
            endif
            if targetexists
                hotkey 'cancel current target'
            endif
            cast 'Reactive Armor'
        endwhile
        if timer ReactiveArmorTimer < 5000
           // Do nothing
        else 
            while casting
                wait 250
            endwhile
            settimer ReactiveArmorTimer 0
        endif 
        wait 250 
    endif

    if EnableProtection = 1 and skill 'magery' >= 40 and not findbuff "Protection" and mana >= MinimumManaToApplyMageryBuffs and diffhits < ActivateAutoHealHPdiff and findtype 3980 self and findtype 3972 self and findtype 3973 self
        cast 'Protection'
        settimer AntiStallTimer 0
        while not casting and timer AntiStallTimer < 3500
            if timer AntiStallTimer > 3500
                settimer AntiStallTimer 0
                break
            endif
            cast 'Protection'
            wait 250
        endwhile
        while casting
            wait 250
        endwhile
    endif

    if EnableBless = 1 and skill 'magery' >= 50 and not findbuff "Cunning" and mana >= MinimumManaToApplyMageryBuffs and diffhits < ActivateAutoHealHPdiff and findtype 3972 self and findtype 3974 self
        if targetexists 
            hotkey 'cancel current target'
        endif
        cast 'Bless'
        settimer AntiStallTimer 0
        while not casting and timer AntiStallTimer < 3500
            if timer AntiStallTimer > 3500
                settimer AntiStallTimer 0
                break
            endif
            cast 'Bless'
            wait 250
        endwhile
        while casting
            wait 250
        endwhile
        wft 1500
        target 'self'
        wait 250
    endif


    //////////////////////////
    //  BEGIN ATTACK LOOP:  //
    //////////////////////////

    while not dead ClosestTarget and find ClosestTarget ground -1 -1 TargetAttackRange and diffhits < ActivateAutoHealHPdiff and AttackModeActive = 1 and TargetSwap != 1
       if skill "Arcane" >= 80 and EnableArcaneWeaponAbility = 1
            settimer ArcaneWeaponAbilityTimer 10000
            if EnableArcaneCodexAbilityHotbar = 1
                if not gumpexists 3954121934
                    yell '[abilitieshotbar'
                    wait 500
                endif
            endif
        endif

        if EnableWeaponCheck = 1 and skill 'Arcane' >= 50 and not findtype "31043|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31045|31047|31049|31051|31053|31055" hand
            if findtype "31043|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31045|31047|31049|31051|31053|31055" self as myArcaneStaff
                for 5
                if findtype "31043|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31045|31047|31049|31051|31053|31055" self as myArcaneStaff
                    getlabel myArcaneStaff myArcaneStafflabel            
                    if "Aspect" in myArcaneStafflabel
                        break
                    elseif "unidentified" in myArcaneStafflabel
                        ignore myArcaneStaff
                    else 
                        break 
                    endif 
                endif 
                endfor 
                dclick myArcaneStaff
                clearignore 
                wait 500
            else
                if timer "ArcaneStaffCheck" > 5000 and EnableOverheadMessages = 1
                    overhead "[ NO ARCANE STAFF! ]" 337
                    settimer "ArcaneStaffCheck" 0
                endif
            endif
