        elseif AutoRecallTime = 1
            if EnableDIYRecallScript = 1
                @setvar! AutoRecallTime 0
                foreach RecallScript in DIYRecallScriptList
                    script RecallScript
                endfor
            else
                if targetexists
                    hotkey 'Cancel Current Target'
                endif

