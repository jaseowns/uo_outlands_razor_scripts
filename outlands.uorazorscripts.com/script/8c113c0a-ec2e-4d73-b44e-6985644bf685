                    // Do nothing
                else
                    if followers > 0
                        if EnableOverheadMessages = 1
                            overhead "[ ACTIVATING CROOK! ]" 2114
                        endif
                        dclick myCrook
                        getlabel backpack backpacklabel
                        wait 250
                    endif
                endif
            else
                if EnableOverheadMessage = 1 or EnableOverheadMessages = 2
                    if timer CrookCheckOverheadTimer > 15000
                        overhead "[ NO CROOK FOUND! ]" 337
                        settimer CrookCheckOverheadTimer 0
                    endif
                endif
            endif
            settimer CrookCheckTimer 0
        endif
    endif

    if EnableEatMagicMushrooms = 1 and AttackModeActive != 2
        if diffmana > EatMushroomManadiff and MakeMushroomAmount > 0 and timer MushroomTimer > 60000
            if counttype 29012 backpack
                clearsysmsg
                dclicktype 29012 backpack
                getlabel backpack backpacklabel
                if insysmsg "You consume a magic mushroom"
                    settimer MushroomTimer 0
                    cooldown "Mushroom" 60000
                    if EnableOverheadMessages = 1
                        overhead '[ EATING SHROOMS... ]' 13
                    endif
                endif                
            elseif EnableOverheadMessages = 1
                overhead '[ OUT OF SHROOMS! ]' 337
            endif
        endif
    endif

    if EnableAutoCarving = 1 and findtype 11552 self and AttackModeActive != 2
        while findtype "corpse" ground -1 -1 2 as deadbody and diffhits < ActivateAutoHealHPdiff 
            settimer SkinningTimeoutTimer 0
            if findtype 11552 self
                if targetexists
                    hotkey 'cancel current target'
                endif

                while not targetexists                    
                    skill 'forensicevaluation'
                    getlabel backpack backpacklabel
                endwhile

                clearsysmsg

                if targetexists and find deadbody ground -1 -1 2
                    target 'self'
                    @ignore deadbody
                    getlabel backpack backpacklabel
                endif

                if insysmsg "You dont see anything nearby"
                    clearsysmsg 
                    break
                else
                    if EnableOverheadMessages = 1 and timer SkinningTimer > 3000 
                        overhead '[ SKINNING... ]' 333
                        settimer SkinningTimer 0
                    endif
                    break
                endif 
            else 
                if EnableOverheadMessages = 1 and timer SkinningTimer > 15000
                    overhead '[ NO SKINNING KNIFE ]' 337
                    settimer SkinningTimer 0
                    break
                endif  
            endif 

            if timer SkinningTimeoutTimer > 1500 or diffhits > ActivateAutoHealHPdiff
                break
            endif 
        endwhile
    endif 

    if targetexists
        if findtype " Elven Spellblade" self
            targettype "Elven Spellblade"
