    ########################
    #   SET YOUR SUMMONS:  #
    ########################

// Total summons count (can be '0' to '5'):
    @setvar! TotalSummonCount 0
        # Must include any active tamed PETS or intended SUMMONS (not mounts)
        # Will trigger summoning if your total follower count drops below this number


// Number of summoned pets ('0' '1' or '2' each, etc.):

    @setvar! SummonEarthElemental_or_AncientMummy 0
    @setvar! SummonWaterElemental_or_RagWitch 0
    @setvar! SummonAirElemental_or_SkeletalFiend 0
    @setvar! SummonFireElemental_or_Lich 0
    @setvar! SummonDemon_or_VampireThrall 0
    @setvar! SummonCreature_or_UndeadCreature 0
    
        # Elemental OR Undead summon depends on 'EnableNecroVengefulSpirit' setting below!
        # Elementals/Demons/Liches/Thralls/etc. occupy '2 of 5' control slots each
        # Summoned creatures occupy '1 of 5' control slots each
        # 'MAXIMUM OF 5 CONTROL SLOTS TOTAL!'    
    
    @setvar! EnableAutoCrookCheck 0
        # If herding skill > 50 and crook is found, crook will be checked for activation

        
    ########################
    #  NAME YOUR SUMMONS:  #
    ########################
        
    @setvar! NameSummonedPets 0
        # If enabled, pets will be named (based on lists below) upon summoning
        # If name is unacceptable, or upon new summons, the next name in the list will be used
        # Lists recycle when all named have been used and will return to the first name 
        # As far as I can tell, you can add as many names as you like to each list! (just add another line: pushlist ExampleSummonNamesList "NEW PET NAME")

            
    // Change and add PET NAMES in lists below (must be unique):  //
        
        if NameSummonedPets = 1

        # EARTH ELEMENTAL/ANCIENT MUMMY NAMES:
            if not listexists EarthEleAncientMummNamesList
                createlist EarthEleAncientMummNamesList
            endif  
            if SummonEarthElemental_or_AncientMummy > 0 and list EarthEleAncientMummNamesList = 0
                pushlist EarthEleAncientMummNamesList "LGCSAPONEA"
                pushlist EarthEleAncientMummNamesList "LGCSAPTWOA"
                pushlist EarthEleAncientMummNamesList "LGCSAPTHREEA"
                pushlist EarthEleAncientMummNamesList "LGCSAPFOURA"
                pushlist EarthEleAncientMummNamesList "LGCSAPFIVEA"
                
            endif
        # WATER ELEMENTAL/RAG WITCH NAMES:
            if not listexists WaterEleRagWitchNamesList
                createlist WaterEleRagWitchNamesList 
            endif 
            if SummonWaterElemental_or_RagWitch > 0 and list WaterEleRagWitchNamesList = 0 
                pushlist WaterEleRagWitchNamesList "LGCSAPONEB"
                pushlist WaterEleRagWitchNamesList "LGCSAPTWOB"
                pushlist WaterEleRagWitchNamesList "LGCSAPTHREEB"
                pushlist WaterEleRagWitchNamesList "LGCSAPFOURB"
                pushlist WaterEleRagWitchNamesList "LGCSAPFIVEB" 
                
            endif
        # AIR ELEMENTAL/SKELETAL FIEND NAMES:
            if not listexists AirEleSkeleFiendNamesList
                createlist AirEleSkeleFiendNamesList
            endif
            if SummonAirElemental_or_SkeletalFiend > 0 and list AirEleSkeleFiendNamesList = 0
                pushlist AirEleSkeleFiendNamesList "LGCSAPONEC"
                pushlist AirEleSkeleFiendNamesList "LGCSAPTWOC"
                pushlist AirEleSkeleFiendNamesList "LGCSAPTHREEC"
                pushlist AirEleSkeleFiendNamesList "LGCSAPFOURC"
                pushlist AirEleSkeleFiendNamesList "LGCSAPFIVEC"
                
            endif      
        # FIRE ELEMENTAL/LICH NAMES:
            if not listexists FireEleLichNamesList 
                createlist FireEleLichNamesList
            endif
            if SummonFireElemental_or_Lich > 0 and list FireEleLichNamesList = 0
                pushlist FireEleLichNamesList "LGCSAPONED"
                pushlist FireEleLichNamesList "LGCSAPTWOD"
                pushlist FireEleLichNamesList "LGCSAPTHREED"
                pushlist FireEleLichNamesList "LGCSAPFOURD"
                pushlist FireEleLichNamesList "LGCSAPFIVED"
                
            endif
        # DEMON/VAMPIRE THRALL NAMES:
            if not listexists DemonVampThrallNamesList
                createlist DemonVampThrallNamesList 
            endif
            if SummonDemon_or_VampireThrall > 0 and list DemonVampThrallNamesList = 0 
                pushlist DemonVampThrallNamesList "LGCSAPONEE"
                pushlist DemonVampThrallNamesList "LGCSAPTWOE"
                pushlist DemonVampThrallNamesList "LGCSAPTHREEE"
                pushlist DemonVampThrallNamesList "LGCSAPFOURE"
                pushlist DemonVampThrallNamesList "LGCSAPFIVEE"
                
            endif
        # CREATURE/UNDEAD CREATURE NAMES:
            if not listexists CreatureNamesList
                createlist CreatureNamesList
            endif
            if SummonCreature_or_UndeadCreature > 0 and list CreatureNamesList = 0 
                pushlist CreatureNamesList "LGCSAPONEF"
                pushlist CreatureNamesList "LGCSAPTWOF"
                pushlist CreatureNamesList "LGCSAPTHREEF"
                pushlist CreatureNamesList "LGCSAPFOURF"
                pushlist CreatureNamesList "LGCSAPFIVEF"
                
            endif
        else
            clearlist EarthEleAncientMummNamesList
            clearlist WaterEleRagWitchNamesList 
            clearlist AirEleSkeleFiendNamesList 
            clearlist FireEleLichNamesList 
            clearlist DemonVampThrallNamesList 
            clearlist CreatureNamesList
        endif 


///////////////////
//  NECROMANCY:  //
///////////////////

@setvar! EnableNecroWither 0
    # Will cast Wither prior to summoning elementals (reduces summoning mana cost)

@setvar! EnableNecroVengefulSpirit 0
    # Vengeful Spirit will summon undead minions instead of elementals (set types/amounts above) 
    @setvar! EnableNecroBloodOath 0
        # 'EnableNecroBloodOath' requires 'EnableNecroVengefulSpirit' to also be enabled (undead summons buff)
        
@setvar! MinimumManaAmounttoNecroBuff 20
    @setvar! EnableNecroStrangle 0
    @setvar! EnableNecroCorpseSkin 0
    @setvar! EnableNecroMindRot 0
    @setvar! EnableNecroEvilOmen 0
        # Necro buffs will be used (during combat) if Unholy Points are sufficient and minimum mana is exceeded
        # For optimum performance 'MinimumManaAmounttoNecroBuff' should be the same or higher than 'CastSmallSpellsBelowMana' (below)
    
@setvar! EnableNecroPainSpike 0
    @setvar! PainSpikeAttackDelay 8000
        # Adjust delay after acquiring a new target before attempting Pain Spike (to accumulate damage) 
        # Increase delay if fighting tougher MOBs. 
        # Timer starts when new target is attacked and delays Pain Spike (must have corpses in range to trigger)

@setvar! EnableNecroPoisonStrike 0
    # '0' for 'Disabled'
    # '1' for 'Apply after Corpse Skin disease delay timer only'
        # DO NOT USE SETTING '1' IF INTENDING TO TRIGGER FROM CAST POISON TICKS (use '2-10' instead!)
        # SETTING '1' IS FOR CORPSE SKIN DISEASE TRIGGERED POISON STRIKES ONLY! (set delay value below)
    # '2' for 'Apply in 2 poison ticks left or less'
    # '3' for 'Apply in 3 poison ticks left or less'
    # '4' for 'Apply in 4 poison ticks left or less'
    # '5' for 'Apply in 5 poison ticks left or less'
    # '6' for 'Apply in 6 poison ticks left or less'
    # '7' for 'Apply in 7 poison ticks left or less'
    # '8' for 'Apply in 8 poison ticks left or less'
    # '9' for 'Apply in 9 poison ticks left or less'
        # Poison Strike will be triggered by remaining Ticks (if spell poisoned) or by Corpse Skin timer (if diseased)
        # If using spell poison, use values '2-10' to set your Poison Strike trigger point (if sufficient Unholy Points available, etc.)
        # Poison Strike settings '2-10' require 'EnableCastPoison' turned on! (below)
        # If NOT using spell poison, use value '1' and set delay below (Corpse Skin must be enabled)

       @setvar! CorpseSkinPoisonStrikeDelay 12000
            # Poison Strike setting '1' requires 'EnableNecroCorpseSkin' turned on (above)
            # Setting 'CorpseSkinPoisonStrikeDelay' is the delay after casting CORPSE SKIN on NEW target before triggering POISON STRIKE
            # Increase delay value if fighting tougher MOBs


//////////////////
//  OFFENSIVE:  //
//////////////////

//  TARGET ATTACKING:  //
    @setvar! TargetAttackRange 10
        # Set your target auto attack range (1-12 tiles) 
        # Targeted grey MOBs within this range will be engaged
        # Grey MOBs will still be targeted and analyzed outside of attack range, but not attacked
    @setvar! CheckClosestTargetTime 5000
        # Adjust the frequency of closest target checks during combat mode
        # If this is set to '0' the target will remain locked until dead or out of range

//  EQUIPPED SPELLBOOK CHECK:  //
    @setvar! EnableSpellbookCheck 0
        # Use '>info' to ID any of your [blessed] spellbook and add the serial here:
        @setvar! MyBlessedSpellbook 0x00000000
            # This will prevent the script from trying to equip it (instead of your aspect spellbook)

//  OPENING SPELLS:  //
    @setvar! EnableCastCurse 0
    @setvar! EnableCastManaDrain 0
        # If enabled, Curse and/or Mana Drain will be cast on NEW targets (or every 60 seconds) before using large spells

//  LARGE DAMAGE SPELLS:  //
    @setvar! EnableCastFlamestrike 1
    @setvar! FlamestrikeCooldown 0

    @setvar! EnableCastExplosion 1
    @setvar! ExplosionCooldown 5000

    @setvar! EnableCastEnergyBolt 1
    @setvar! EnergyBoltCooldown 2500
    
    @setvar! EnableCastMindblast 0
    @setvar! MindblastCooldown 0
        # Large damage spells will be cast exclusively above 'CastSmallSpellsBelowMana' set point (below)
        # Flamestrike is prioritized over all the others (if enabled)
        # Increase the small spell mana set point to use them more often

//  SMALL DAMAGE SPELLS:  //
    @setvar! CastSmallSpellsBelowMana 20
        # Script will prioritize big spells (FS, xplo, ebolt, MB) above this mana value
        # Magic Arrow, Harm, Fireball and Lightning will only be cast below this point
        # Value can range from '10-110' (lower than '10' may cause errors)
        # Spell cooldown values (below) can be increased to reduce casting frequency if necessary

    @setvar! EnableCastMagicArrow 0
    @setvar! MagicArrowCooldown 15000

    @setvar! EnableCastHarm 0
    @setvar! HarmCooldown 15000

    @setvar! EnableCastFireball 0
    @setvar! FireballCooldown 15000

    @setvar! EnableCastLightning 0
    @setvar! LightningCooldown 15000

//  POISON SPELL:  //  
    @setvar! EnableCastPoison 0
        @setvar! SetPoisonLevel 0
            # '0' for 'Greater or less'
            # '1' for 'Deadly'
            # '2' for 'Lethal'
            # Poison spell will be cast repeatedly on targeted MOB until set poison level is reached

//  MEDITATION SETTINGS:  //
    @setvar! EnableMeditation 0
        @setvar! MeditateWhenManaBelow 11
        @setvar! MeditateUntilManaReaches 50
            # If enabled, meditation will trigger if mana falls below 'MeditateWhenManaBelow'
            # Peace Mode will be activated while meditating
            # Script will resume if HP drops below 'ActivateAutoHealHPdiff' (below) or if War Mode is activated 
            # Otherwise, meditation ends when 'MeditateUntilManaReaches' is reached and script resumes


//////////////////////////
//      DEFENSIVE:      //
//////////////////////////

@setvar! EnableAutoParalyzePouch 1
    # Will automatically pop trapped pouches if paralyzed (will also trigger auto recall/gating, if enabled below)

@setvar! AutoTrapYourPouches 0
    # Will automatically cast 'Magic Trap' any untrapped pouches found in your backpack

@setvar! ActivateAutoHealHPdiff 40
    # If hit point differential exceeds this number, the Auto Heal loop will activate and prioritize keeping you alive
    # Keep this setting equal to or less than 'CastGreaterHealHPdiff' for optimal performance 
    # Priority healing loop works best with all healing options turned on ('EnableCastGreaterHeal', 'EnableCastHeal', 'EnableHealPotion', etc.)
@setvar! DeactivateAutoHealHPdiff 0
    # Prioritized healing loop will continue until this hit point differential is met or exceeded 
    # Keep this setting less than 'ActivateAutoHealHPdiff' above 
    # A setting of '0' will restore you to full health before returning to attack mode 
        
    @setvar! EnableCastGreaterHeal 1
    @setvar! EnableCastHeal 1

        @setvar! CastGreaterHealHPdiff 40
        @setvar! CastHealHPdiff 60
        @setvar! CastEmergencyHealHPdiff 80
            # If damage exceeds 'CastHealHPdiff' Heal spell will be used to quickly recover before casting Greater Heal spell
            # If damage exceeds 'CastGreaterHealHPdiff' but is less than 'CastHealHPdiff' then Greater Heal spell will be used
            # If damage exceeds 'CastEmergencyHealHPdiff' then Heal spell will be spammed to keep you alive
            # If poisoned and 'EnableCastCure' is enabled, Cure spell will be cast until no longer poisoned
            # Heal/Cure potions are always prioritized (if enabled below and found in inventory) for instant healing along with spellcasts

    @setvar! EnableCastCure 1
    @setvar! EnablePanaceaAbility 0
        # If enabled and unlocked in potion codex, orange potion will be consumed if bleeding or diseased (if not on cooldown)
            
@setvar! MinimumManaToApplyMageryBuffs 40
    # Magery Buffs (below) will only be applied if mana is above this set point
    @setvar! EnableMagicReflection 0
    @setvar! EnableBless 0
    @setvar! EnableReactiveArmour 0

        @setvar! EnableProtection 0
        @setvar! EnableArchProtection 0
            # Only enable 'Protection' or 'ArchProtection' at once - not both!
            # If both are enabled only Protection will be cast (as the trigger condition is the same for each)

@setvar! EnableFrostAspect 0
    @setvar! FrostAspectTier 0
    # Set your Frost Aspect level (if using Frost Aspect armour)
    #   This will automatically set your optional Frost Shell Cooldown length
    #   Add cooldowns in UO options 'Frost Shell Cooldown' and 'Frost Shell Active' (case sensitive)


//////////////////////////
//       POTIONS:       //
//////////////////////////

@setvar! EnableAutoExplosionPots 0
    # Uses 'Telekinesis' spell to make new target MOBs sticky first (if Alchemy skill < 80)

@setvar! EnableHealPotion 1
@setvar! EnableCurePotion 1
@setvar! EnableRefreshPotion 1

    @setvar! HealPotionHPdiff 30
    @setvar! RefreshPotionSPdiff 10
        # Adjust HP diff set points for Heal and Refresh potion 
        # Heal potions will be prioritized over all healing options if not on cooldown 
        # Cure pots will be used as needed (if enabled and found in inventory) and prioritized over spellcasts

    @setvar! SetHealingPotionCooldown 10000
        # This value only affects your OPTIONAL COOLDOWN BAR (script uses other checks to verify heal pots are available)
        # You can reduce this value if using Potion Codex
        # Add cooldown in UO options 'Healing Potion' (case sensitive)


    @setvar! EnableStrengthPotion 0
    @setvar! EnableAgilityPotion 0
    @setvar! EnableMagicResistPotion 0
        # Strength, Agility and Resist potions will auto-buff when effects wear off (if enabled) *
        //    * If Alchemy skill is greater than 0.0 but less than 2.0 the script will take your next STRENGTH potion BEFORE the effect wears off!
        //      For example, with an Alchemy skill of 1.0 your buff duration will be 2m 05s and a new strength potion is available after 2 mins
        //      Taking your next potion during the extra 5 second buffer will keep your HP at 120 (instead of a temporary drop and HP of 100/120)

@setvar! EnableUsePotionKegs 0
    # Will auto fill empty bottles from potion kegs if counts drop below set amounts:
    # Requires potion kegs and empty bottles (pack extra if using explosion potions) 
    # A good way to carry lots of potions without weighing you down

    if EnableUsePotionKegs = 1
        @setvar! HealingPotionAmount 5
        @setvar! CurePotionAmount 5
        @setvar! RefreshPotionAmount 2
        @setvar! StrengthPotionAmount 1
        @setvar! AgilityPotionAmount 1
        @setvar! ResistPotionAmount 1
        @setvar! ExplosionPotionAmount 2
        @setvar! PoisonPotionAmount 0
    endif
    
@setvar! EnableEatMagicMushrooms 0
    @setvar! EatMushroomManadiff 30
        # Will consume Magic Mushrooms when mana diff exceeded (if not on cooldown)

@setvar! EnableMagicMushroomMaker 0
    @setvar! MakeMushroomAmount 5
        # Will automatically make mushrooms when you run out (to set amount)

        
//////////////////////////
//       UTILITY:       //
//////////////////////////

@setvar! EnableOverheadMessages 1
    # '0'  Most overhead messages will be turned OFF (minimal target indicators will remain)
    # '1'  All overhead messages will be turned ON (default mode)
    # '2'  Only overhead messages for targeting or important warnings will be turned ON (my preferred mode!)

@setvar! EnableAutoCarving 0
    # Will automatically carve nearby corpses when found (requires SKINNING KNIFE)

@setvar! EnableEatingFood 0
    # Will eat food if not buffed (requires delectable FOOD TRAYS)
    
@setvar! EnableAutoSatchels 0
    # Will automatically move potions and/or reagents to satchels (requires POTION or WIZARD SATCHELS)

@setvar! EnableGoldVacuum 0
    # Will automatically pickup discarded GOLD COINS nearby (2 tiles)
    # WARNING: This can cause you to grab large stacks of gold (and weigh you down) if you are not careful!

@setvar! EnableDungeonCleanup 0
    # Will automatically pickup discarded resources (regs, ingots, boards, etc.) nearby (2 tiles)
    
@setvar! EnableDropGoldWhenOverweight 0
    @setvar! DropGoldAmount 500
    # Will drop set amount of gold repeatedly when overweight until no longer impeded 

@setvar! EnablePutLootinLockBox 0
    # Will move all loot into wooden box and then immediately lock it (requires WOODEN BOX and COPPER KEY)
    #  Key must be kept outside the container (but not in your main pack where it can be stolen)
    #  All loot will be automatically moved and secured while FARMING
    # This is a MUST for dungeon farming IMO - if you are not using this, you really should!

@setvar! EnableLootBag 0
    # Will open your selected LOOTBAG when unloading at HOME/INN/BANK (if using BUILT IN AUTO RECALL)
    #  This should be the bag that is set as your 'Grab Bag' in Gridloot, etc.
    #  You will be prompted to select a new loot bag whenever one is not found in your inventory
    #  This can be retargeted in the 'Options' tab above the script (or by a full script reset)
    
@setvar! EnableWeightWarningMessage 1
    @setvar! GreenWarningDiffWeight 50
    @setvar! YellowWarningDiffWeight 25
    @setvar! RedWeightLimitDiffWeight 5
        # Will display overhead warnings that change colour as they approach your carry weight limit (Green, Yellow and Red)
        # Red weight limit will trigger AUTO RECALL or AUTO DUNGEON GATE if enabled below (otherwise just an overhead warning and script ends)


/////////////////////////
//  AUTO RECALL/GATE:  //
/////////////////////////

    ##########################
    #      PK TRIGGERS:      #
    ##########################

    //  RED RECALL/ESCAPE (w/ TRACKING SKILL):  //
        
        if skill 'Tracking' >= 50
            
            @setvar! EnableTrackingAutoRecall 0
                # Make sure "Ignore Houses/Ships" is checked in the Tracking skill menu!
                
            if EnableTrackingAutoRecall = 1
                @setvar! PKTrackingRange 50
                    # Range can be 40, 50 or 60 tiles (or 0 will trigger Auto Recall regardless of range)

                @setvar! EnableRedAlertOverhead 1
                    # If your build has tracking skill, I highly recommend setting up a Razor overhead message instead of using the script one:
                        // This will display PK name/distance overhead when tracked!
                        // Add overhead message w/ a trigger of "Now tracking" and message '[ RED ALERT: {3} ]'  (hue 335)
                        // Then a second with a trigger of "Distance to destination" and message '[ {4} TILES AWAY! ]'  (hue 253)
                        // Once complete you should disable "EnableRedAlertOverhead" above
              
                if WILDERNESSMODE = 1
                    @setvar! EnableAutoRedRecall 0
                        # Auto Recall triggered if PK is tracked within 'PKTrackingRange' tiles (wilderness only)
                    
                elseif DUNGEONMODE = 1
                     @setvar! EnableAutoRedDungeonGate 0
                        # Auto Dungeon Gate triggered if PK is tracked within 'PKTrackingRange' tiles (dungeons only)
                endif
            endif 
            

    //  RED RECALL/ESCAPE (w/ NO TRACKING SKILL):  //
        
        elseif skill 'Tracking' < 50
            
            @setvar! EnablePKradar 0
                # PK radar must be enabled for Auto Red Recall/Dungeon Gate to function (w/o Tracking Skill)
                # Radar checks for PK targets within range (roughly every 2 secs) and will alert with an overhead message and/or trigger escapes

                
            if EnablePKradar = 1
                @setvar! EnableRedAlertOverhead 1
                    # Optional overhead message alert when PK is targeted (independant of other overhead message settings)
                    
                if WILDERNESSMODE = 1
                    @setvar! EnableAutoRedRecall 1
                        # Auto Recall triggered if PK comes into (~12 tile) target range (wilderness only)
                        
                elseif DUNGEONMODE = 1
                    @setvar! EnableAutoRedDungeonGate 1
                        # Auto Dungeon Gate triggered if PK comes into (~12 tile) target range (dungeons only)
                endif
            endif 
        endif

        ############################
        #     WEIGHT TRIGGERS:     #
        ############################

            if WILDERNESSMODE = 1 and EnableWeightWarningMessage = 1
                @setvar! EnableAutoWeightRecall 0
                
            elseif DUNGEONMODE = 1 and EnableWeightWarningMessage = 1
                @setvar! EnableAutoWeightDungeonGate 0
                @setvar! EnableRecallAfterDungeonGate 0
            endif
            # Requires 'EnableWeightWarningMessage' to be enabled (above) and is triggered by Red weight limit
            # Auto Recall or Auto Dungeon Gating will be triggered if 'RedWeightLimitDiffWeight' is reached (set above)
            # Auto Recall can also be triggered (optionally) upon successful dungeon gate exit via 'EnableRecallAfterDungeonGate'
            
        ############################
        #  RESURRECTION TRIGGERS:  #
        ############################

            @setvar! EnableRecallAfterResurrection 0
                # Must have [blessed] runebook charged w/ scrolls to recall after resurrection!
            

        #########################################################
        ####  YOU CAN TRIGGER YOUR OWN RAZOR RECALL SCRIPT:  ####
        #########################################################
        
            @setvar! EnableDIYRecallScript 0
                # Enable use of your own Razor script for Auto Recall (otherwise script will prompt for a Runebook and use built-in auto recall)

            //  Type the name of your own Home Recall Razor script here:  //
                if EnableDIYRecallScript = 1
                    createlist DIYRecallScriptList
                    pushlist DIYRecallScriptList " YOUR DIY RECALL SCRIPT NAME "
                endif

            ##########################################################
            ####  OR USE THE BUILT-IN AUTO RECALL/ESCAPE SCRIPT:  ####
            ##########################################################

                @setvar! EnableCastRecall 1
                    # '0' for 'Scrolls in charged Runebook to "first" rune'
                    # '1' for 'Cast Recall to Runebook using "default" rune'                  
                    
            //  AUTO RECALL DESTINATION (choose only one):  //
                    @setvar! BankRecall 0
                    @setvar! OwnerInnRecall 0
                    @setvar! CoOwnerInnRecall 0
                    @setvar! InsideHouseRecall 0
                    @setvar! OutsideHouseRecall 0

                    if OutsideHouseRecall = 1
                        @setvar! EnableCloseMyDoor 0
                        @setvar! MyDoor 0x0000000
                        # Use ">info" to ID your own house door (to quickly close it behind you)
                    endif

                    @setvar! HideAtHomeorInn 0
                        # Will use hiding skill once inside home or inn room


            //  LOADOUT RESET (after RECALL):  //
                    #  Safe, Repair Bench, Resource Stockpile, Storage Shelf, Magic Recycler and/or Loot Chest must be found within 2 tiles!
                    #  Storage Tomes can be locked down (within 2 tiles) or located inside Loot Chest or Storage Tome Container

                    @setvar! EnableAutoRecallOverheadMessages 1
                        # Controls overhead messages for recall section only

                        @setvar! EnableDispelSummonsAfterRecall 0
                            # Casts Mass Dispel on your summons after Recall success
                        @setvar! EnableSafeDeposit 0
                            # Will deposit all gold and doubloons found in inventory
                        @setvar! EnableRepairBench 0
                            # Will repair all equipment (Repair Bench must have charges available)
                        @setvar! EnableResourceStockpile 0
                            # Will deposit all resources (ingots, boards, gems, etc.
                        @setvar! EnableStorageShelf 0
                            # Will restock shelf and then resupply a fresh loadout
                        @setvar! EnableMagicRecycler 0
                            # Will add all unidentified magic items to your Recycler 
                        @setvar! EnableRecycleItemsWhenFull 0
                            # If Recycler is full, it will attempt to ID, Recycle and deposit resources (if stockpile nearby) before adding items
                        @setvar! EnableStorageTomes 0
                            # Will add items to any nearby storage tomes (skill scrolls, dyes, runes, maps, cards, etc)
                            @setvar! EnableStorageTomeContainer 0
                                # Script checks on ground (2 tiles) or in LOOT CHEST (enable below) by default
                                # Otherwise you can designate a TOME CONTAINER to check for your books
                        @setvar! EnableReagentSplitter 0
                            # Will split reagents into smaller stacks after shelf resupply
                        @setvar! EnableLootChest 0
                            # Will open selected chest to store non-shelf/stockpile/tome items in your HOME/INN/BANK (uses Razor organizer agents 06-09)


            //  LOADOUT RESET (after DEATH): 
                    # This variable will dress you and reorganize your backpack after death (see instructions below)
                    # Your pack will be setup with anti-theft measures and all aspects will be reactivated, etc. 

                    @setvar! EnableDressAfterResurrection 0
                        # Must have a Razor 'Dress List' named 'UltimateSummoner' for all your [blessed] wearables

                        @setvar! EnableResetInventoryAfterDeath 0
                        @setvar! EnableSetMainPouchOrganizer01 0
                        //  IMPT: 'EnableResetInventoryAfterDeath' Requires an equal amount of TRAPPED POUCHES (in shelf loadout) and SCISSORS [blessed] (in backpack)
                        //  Loadout also requires 1 UNTRAPPED POUCH (for main inventory - optionally set as Organizer Agent-01 above) and 1 BAG (for loot, etc.)
                        //  Script will put scissors in each trapped pouch (to keep them from being grabbed during future shelf loading)
                        //  Script then STACKS any trapped pouches on top of your main inventory pouch
                        //  Loot bag will be moved into main inventory pouch and automatically set as your Grab Bag for Gridloot, etc.
                        //  Script will then hide the stack underneath an ATLAS and put a DECOY TRAPPED POUCH out in the open
                        //  ASPECT WEAPON and ARMOR will be re-activated automatically and HP restored to MAX
                        //  Loadout reset finishes by opening backpack, main pouch, loot bag and any satchels


/////////////////////////
//    SCRIPT MODES:    //
/////////////////////////

    // I use this variable to setup multiple "modes" with different hotkeys.
        # Copy and paste to new script and update variables for different setups (Dungeon, Wilderness, SYG, etc.)
        # Just change the NUMBERS (ie. 'if ScriptMode = 2'/'@setvar! ScriptMode 2') and overhead message (ie.overhead '[ WILDERNESS MODE ]' 1182) for each version
        # Script will only display overhead mode message when switching between modes or upon first run of a new client login
        # I use a ROG Ally and set each hotkey to a different button (A, B, X, Y) and have multiple script modes at the ready!

        if DUNGEONMODE = 1
            if ScriptMode = 1
                // Do nothing
            else
                overhead '[ DUNGEON MODE ]' 2338
                @setvar! ScriptMode 1
                hotkey 'Toggle War Only'
                @setvar! SkipTimers 0
            endif
        elseif WILDERNESSMODE = 1
            if ScriptMode = 2
                // Do nothing
            else
                overhead '[ WILDERNESS MODE ]' 1182
                @setvar! ScriptMode 2
                hotkey 'Toggle War Only'
                @setvar! SkipTimers 0
            endif
        endif


