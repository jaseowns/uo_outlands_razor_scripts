# Automation by Jaseowns
## Script: Draven's Train poisoning from 55 to 120
## Created by: doomshallot#0
#############################################

# Script by DRAVEN SMASH
# Stand next to your shelf
# Have 1 MAGICAL Kryss in your bag
# Set your resupply for 1 Greater, Deadly, and Lethal Potion
# SeT your resupply for 5 Cures
# Set your resupply for 10 bandages (if you have healing)
# Set your resupply for 5 Heals (if you do not have healing)

while not poisoned and hp = maxhp

if findtype "kryss" backpack as weapon

if skill "Poisoning" < 55
    overhead 'NEED TO MANUALLY TRAIN TO 55'
    stop
elseif skill "Poisoning" < 80
    menu weapon 2
    wait 4000
elseif skill "Poisoning" < 100 
    menu weapon 1
    wait 4000
elseif skill "Poisoning" < 120
    menu weapon 0
    wait 4000
else
    stop
endif

if findtype "storage shelf" ground -1 -1 2 as shelf
    overhead 'Shelf Restocking'
    menu shelf 0
    wait 200
    target self
    wait 200
endif

if findtype "storage shelf" ground -1 -1 2 as shelf
    overhead 'Shelf Resupplying'
    menu shelf 1
    wait 200
endif

endif
wait 250
endwhile

while poisoned
    if findtype "Orange Potion" self
    dclicktype "Orange Potion"
    sysmsg "Cure pot" 55
    wait 400
    endif
endwhile

if skill "Healing" >= 80
    while hp != maxhp
        if not bandaging and findtype "clean bandage%s%" backpack as item
            dclick item
            wft 500
            target self
            wait 500
        endif
    endwhile
else
    while hp != maxhp
        if findtype "Yellow Potion" self
            dclicktype "Yellow Potion"
            sysmsg "Heal pot" 55
            wait 400
        endif
    endwhile
endif

replay