                                sysmsg "You play another doozey and distract your provoked target, too!" 69
                            endif
                        elseif insysmsg "fail to discord"
                            settimer "DiscordanceTimer" 5500
                            if EnableOverheadMessages = 1 or EnableOverheadMessages = 2
                                overhead "[ DISCORD FAIL! ]" 37
                            else
                                overhead ' Ď ' 37
                                settimer "NextTargetTimer" 0
                            endif
                            sysmsg "You fail to discord your target!" 337
                            wait 250
                        else
                            if not find NextClosestTarget ground -1 -1 TargetBardingRange or dead NextClosestTarget
                                break
                            endif
                        endif
                    else
                        if not find NextClosestTarget ground -1 -1 TargetBardingRange or dead NextClosestTarget
                            break
                        endif
                    endif
                endif
            endif
