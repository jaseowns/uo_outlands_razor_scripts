// By InCeptor for when your caller needs you to actually be loaded but you also need to smoke... now you no longer need to choose!
// keeps a spell loaded and ready for use while your crew is taking a waypoint or flag or just waiting  
while not dead
while mana < 9000
    //   cast 36
      cast 51
                      while targetexists and not pvp 
                          overhead 'ima gauna git chu!' 27
                      endwhile
endwhile
if pvp 
hotkey 'Next non Friendly Player Target'
endif
endwhile