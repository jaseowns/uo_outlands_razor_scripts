# Bapeths Manual Override
#
# Script will loop into "Master Background", "Bapeths Modern Dungeon Picker", "Bapeths Trapper Background" or "Bapeths Stabber Background" if you have it in your script library
#
# To clear Manual Override, play the script then stop it / cancel your target before selecting anything
#
# Use this script in place of your "Set Last Target" hotkey 
#
# Script starts here
@unsetvar "Manual Override"
@unsetvar "BapPVMProvoSecondTarget"
removetimer ProvoRegularMobRetry
removetimer BapProvoMoveToDiscordAOE
createtimer BapSeekReProvo
hotkey 'Set Last Target'
overhead "Set Manual Override" 45
wft 500
while targetexists 
    if timerexists "BapProvo" or timerexists "BapPeace" and gumpexists 341416395
        hotkey "Cancel Current Target"
        script "Bapeths Trapper Background"
    endif
endwhile
if not targetexists 
    @setvar "Manual Override" lasttarget
    overhead "Override Set!" 68 "Manual Override"
endif

if skill "Lockpicking" >= 80
    pause 150
    script "Bapeths Modern Dungeon Picker"
endif

if skill "Stealth" = 120
    script "Bapeths Stabber Background"
endif

if skill "Fishing" >= 80
    script 'Master Background'
endif

if skill "Discordance" >= 80 and skill "Tinkering" >= 80
    script "Bapeths Trapper Background"
endif