        if EnableOverheadMessages = 1
            if insysmsg 'You charge your spell with additional energy' 
            overhead '[ CHARGED SPELL! ]' 22
            endif

            if insysmsg 'You generate mana for your spell' 
                overhead '[ MANA REFUNDED! ]' 11
            endif
            
            if insysmsg "You parry the spell"
                overhead "[ SPELL PARRY ]" 111
            endif

            if insysmsg "You enter a state of arcane clarity" 
                overhead '[ CLARITY! ]' 11
            endif
            
            if insysmsg "Your attack places a hex" 
                overhead '[ HEX ACTIVE ]' 14 ClosestTarget
            endif
            
            if insysmsg "Mana Thief activated" 
                overhead '[ MANA THIEF! ]' 14
            endif
            
            if insysmsg "100% arcane buildup" 
                overhead '[ ARCANE BUILDUP 100%! ]' 2114
            endif
