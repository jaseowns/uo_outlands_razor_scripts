# Fire the cannons by Jaseowns
# UO Outlands

@setvar! jaseowns_FireOrder1 2
@setvar! jaseowns_FireOrder2 3
@setvar! jaseowns_FireOrder3 4
@setvar! jaseowns_FireOrder4 1

if jaseowns_TargetShip != 0
        
    if not targetexists 
        if jaseowns_FireOrder1 = 1
            say "[LesserAbility"
        elseif jaseowns_FireOrder1 = 2
            say "[RegularAbility"
        elseif jaseowns_FireOrder1 = 3
            say "[GreaterAbility"
        elseif jaseowns_FireOrder1 = 4
            say "[AuxiliaryAbility"
        endif
        wft 500
    endif

    if not targetexists 
        if jaseowns_FireOrder2 = 1
            say "[LesserAbility"
        elseif jaseowns_FireOrder2 = 2
            say "[RegularAbility"
        elseif jaseowns_FireOrder2 = 3
            say "[GreaterAbility"
        elseif jaseowns_FireOrder2 = 4
            say "[AuxiliaryAbility"
        endif
        wft 500
    endif

    if not targetexists 
        if jaseowns_FireOrder3 = 1
            say "[LesserAbility"
        elseif jaseowns_FireOrder3 = 2
            say "[RegularAbility"
        elseif jaseowns_FireOrder3 = 3
            say "[GreaterAbility"
        elseif jaseowns_FireOrder3 = 4
            say "[AuxiliaryAbility"
        endif
        wft 500
    endif

    if not targetexists 
        if jaseowns_FireOrder4 = 1
            say "[LesserAbility"
        elseif jaseowns_FireOrder4 = 2
            say "[RegularAbility"
        elseif jaseowns_FireOrder4 = 3
            say "[GreaterAbility"
        elseif jaseowns_FireOrder4 = 4
            say "[AuxiliaryAbility"
        endif
        wft 500
    endif
endif

if targetexists 
    target jaseowns_TargetShip
endif

if listexists jaseowns_PreviousScript
    foreach myScript in jaseowns_PreviousScript
        hotkey myScript
    endfor
endif
