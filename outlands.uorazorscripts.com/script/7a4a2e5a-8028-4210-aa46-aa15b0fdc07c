# Shipping Crate Helper by JaseOwns
# UO Outlands
@setvar! globalTimeout 650
@clearignore 

while findtype 3645 ground -1 -1 2 as jaseCrate
    getlabel jaseCrate desc
    if "locked" in desc or "secure" in desc or "0 items, 0 stones" in desc
        @ignore jaseCrate
    else
        dclick jaseCrate
        wait globalTimeout
        overhead "We got one maybe" 89 jaseCrate    
        @setvar! myDynamicFind 0
        if findtype "bank deposit safe" ground -1 -1 2 as myDyanmicFindValue
            @setvar! myDynamicFind myDyanmicFindValue   
        elseif findtype "bank deposit safe" convenienceChest -1 -1 2 as myDyanmicFindValue
            @setvar! myDynamicFind myDyanmicFindValue   
        endif
        if myDynamicFind != 0
            while findtype "gold coin" backpack as gold
                lift gold 60000
                drop myDynamicFind -1 -1 -1
                wait globalTimeout
            endwhile
            while findtype "gold coin" jaseCrate as gold
                lift gold 60000
                drop myDynamicFind -1 -1 -1
                wait globalTimeout
            endwhile
            while findtype "doubloon" backpack as joubloons
                lift joubloons 60000
                drop myDynamicFind -1 -1 -1
                wait globalTimeout
            endwhile
            while findtype "doubloon" jaseCrate as joubloons
                lift joubloons 60000
                drop myDynamicFind -1 -1 -1
                wait globalTimeout
            endwhile
        endif
        # 3530 fishing net
        while findtype 31169|3568|3570|3571|3572|3573|3713|3719|3721|3740|3742|3762|3763|3834|3909|3911|3913|3915|3917|3920|3922|3932|3934|3937|3938|5040|5042|5044|5046|5049|5112|5115|5117|5119|5121|5123|5125|5127|5177|5179|5181|5182|5185|5187|7026|7027|7029|7031|7033|7034|7035|7107|7109|10245|20006|20008|20010|20012|20014|20016|22187|30988|30989|30990|30991|30992|30993|30994|30995|30996|30997|30998|30999|31000|31001|31002|31014|31017|31019|31021|31023|31025|31027|31029|31031|31033|31035|31037|31038|31041|31043|31045|31047|31049|31051|31053|31055|31128|31130|31141|31142|31176|31178|31180|31182|31184|31186|31188|31190|576|2472|2475|2594|2597|2744|2750|2760|2771|2778|2799|3648|3649|3650|3651|3708|3712|3735|3736|3737|3738|3827|3836|3838|3839|3842|3843|3985|4248|5356|5359|5981|8826|12686|15297|17087|17686|19717|22244|22336|23996|23997|24343|24434|29025|29036|29040|29832|29833|43166|43179|43206|48405|48407|3834|6238|8786|8787|8901|11881|11882|11883|11884|11885|11886|11887|11888|11889|11890|11891|11893|11895|29103|29104|29105|41471|42516|45340|45823|5056|5059|5060|5061|5063|5070|5074|5075|5076|5078|5085|5089|5090|5101|5103|5105|5106|5129|5131|5132|5135|5138|5139|5142|5143|5144|5146|5201|5203|5204|5205|5207|7169|7170|7173|7175|7177|7179|7181|7610|7947|31003|31004|31005|31006|31007|31008|31009|31010|31011|31012|31015|31191|4025|4026|24434|43206|29363|43166|22336|29348|17087|3985|8826|3827|29030|3836|5981|4248|5359|3839|3838|3843|2597|29036|48407|3834|3865|3859|3885|3856|3878|3877|3873|3861|3862|576|5123|7177|7027|3920|5131|5179|5075|3980|5060|5076|5042|10245|3938|3913|7169|3909|5063|5089|3981|7170|7033|3976|3762|5040|5103|5117|7181|7029|3568|6264|3742|5139|6263|7026|5125|3740|5121|3973|3974|5204|5105|5185|5078|5115|7175|5059|7034|3915|5112|5070|5049|5119|5205|5046|3962|3934|7035|3911|7179|5106|5143|3573|3719|5177|7610|5181|3917|5132|3963|7031|5207|5056|5085|3763|5129|5187|3721|3972|5138|3570|5101|5061|5074|5142|5182|5146|6265|5090|5203|5044|5144|3932|5201|5127|3572|7173|513