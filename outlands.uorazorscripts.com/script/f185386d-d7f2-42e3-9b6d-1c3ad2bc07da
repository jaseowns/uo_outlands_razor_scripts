# Automation by Jaseowns
## Script: Apply poison to weapon
## Created by: blnbs#0
#############################################

// made by Balan
// create a cooldown named "Poisoning".
// this script will attempt to poison your equipped weapon until it succeeds

while poisoned
    dclicktype "orange potion"
    wait 500
endwhile

if findlayer self righthand as  weapon
    while findtype "green potion" self as poipot    
        while not insysmsg "apply the poison"
            while cooldown "Poisoning" > 0
                wait 200
            endwhile
            overhead "Attempting to apply poison..." 0
            menu weapon 0
            cooldown "Poisoning" 4200
            while not insysmsg "fail to apply"                
                wait 200
                if poisoned
                    loop
                endif
                if insysmsg "apply the poison"
                    overhead "Poison Applied!"
                    stop
                endif
            endwhile
        endwhile
        overhead "Poison Applied!"
    endwhile
    overhead "Out of poison pots..." 0
else
    overhead "Equip weapon..." 0
endif