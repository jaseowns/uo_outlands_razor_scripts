@setvar! 'MagicRecycler4' "0x4288510F"

// Create item lists if they dont exist
if not listexists 'items'
    createlist 'items'
endif
if not listexists 'aspects'
    createlist 'aspects'
endif
if not listexists 'skillscrolls'
    createlist 'skillscrolls'
endif
// Clear any existing item lists
clearlist 'items'
clearlist 'aspects'
clearlist 'skillscrolls'

@setvar! CurrentChest DistroChest1
