            elseif skill 'Mace Fighting' >= 50 and find ClosestTarget ground -1 -1 TargetAttackRange
                if timer 'WeaponAbilityTimer' > WeaponAbilityCooldown and UsePummelAbility = 1
                    clearsysmsg
                    yell "[WeaponAbility1"
                    wait 250
