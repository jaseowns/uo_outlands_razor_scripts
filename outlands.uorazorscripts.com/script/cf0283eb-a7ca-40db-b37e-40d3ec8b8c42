# Sazeracs Quick Hold Looter (v1.01)
#
# Last Updated: 3/18/2026
#
# Script by: Sazerac (Discord: mrdies)
#
# This variable simply forces the setup of your TempLootBag, but it should automatically setup on first-run.

@setvar! ForceSetup 0

# Ensure the above variable is swapped back to 0 if you do not want to force the Loot Bag to be reset.
#
# Instructions:
# - Have a container you wish to use as a Quick Drop Loot Container in your backpack.
# - Walk near Boat Hold you wish to loot. Run the script & follow prompt. (Select your bag or backpack.)
# - Profit.

unsetvar ActiveHoldToLoot
@setvar! HatchFindFail 1

if not varexist 'TempLootBag' or ForceSetup = 1
    overhead 'Please select the CRATE or CONTAINER you will store loot INTO for Quick Dropping.'
    @setvar TempLootBag
    overhead 'Temp Loot Bag set.'
endif

if not find 'TempLootBag'
    overhead 'Previous Loot Bag undetected. Please select a new one.'
    @setvar TempLootBag
    overhead 'Active Loot Bag set.'
endif

if findtype 'hatch' ground any any 2 as 'ActiveHoldToLoot'
    
    @setvar HatchFindFail 0
    
    dclick ActiveHoldToLoot
    wait 1000

    while findtype 39889|3712|29833|45298|15296|20006|31041|30997|39891|31178|31190|31186|31019|31055|31025|31035|31053|39912|31027|31191|31001|31029|31182|37181|31172|31049|31010|31128|30994|30990|31011|0997|31169|31051|30993|20010|30996|39909|31002|31038|20014|39916|7107|30991|31014|31007|30998|31176|20012|31142|31000|31005|31023|31043|51098|31033|30999|20008|39917|39898|31037|31008|39918|31021|31184|31047|1055|31188|31031|30989|30988|7109|30995|20016|1043|31009|31130|31180|30992|31180|31003|31006|31012|4026|31004|31045|31017|31141|20006|31015|4026|5905|4025|17686|3891|39917|39891|3821|4225|2539|17617|17619|2426|7708|24434|43206|29363|43166|22336|29348|17087|3985|8826|3827|29030|3836|5981|4248|5359|3839|3838|3843|2597|29036|48407|3834|3865|3859|3885|3856|3878|3877|3873|3861|3862|576|5123|7177|7027|3920|5131|5179|5075|3980|5060|5076|5042|10245|3938|3913|7169|3909|5063|5089|3981|7170|7033|3976|3762|5040|5103|5117|7181|7029|3568|6264|3742|5139|6263|7026|5125|3740|5121|3973|3974|5204|5105|5185|5078|5115|7175|5059|7034|3713|3915|5112|5070|5049|5119|5205|5046|3962|3934|7035|3911|7179|5106|5143|3573|3719|5177|7610|5181|3917|5132|3963|7031|5207|5056|5085|3763|5129|5187|3721|3972|5138|3570|5101|5061|5074|5142|5182|5146|6265|5090|5203|5044|5144|3932|5201|5127|3572|7173|5135|3937|3571|22326|27611|9917|3821|5356|8455|5362|45315|8454|22187|5901|7163|3903|126863854|7981|7982|7983|7984|7985|7986|7987|7988|7989|7990|7991|7992|7993|7994|7995|7996|7997|7998|7999|8000|8001|8002|8003|8004|8005|8006|8007|8008|8009|8010|8011|8012|8013|8014|8015|8016|8017|8018|8019|8020|8021|8022|8023|8024|8025|8026|8027|8028|8029|8030|8031|8032|8033|8034|8035|8036|8037|8038|8039|8040|8041|8042|8033|8044|3854|2545 ActiveHoldToLoot as YourValuables
            overhead 'Looting...'
            @drop TempLootBag
            lift YourValuables 60000
            wait 100
            drop TempLootBag -1 -1 0
            wait 100
    endwhile
    
endif

if HatchFindFail = 1
    
    overhead 'Failed to find Hold.'
    overhead 'Select what to loot.'
    overhead '(This can fail due to a bug.)' 38
    setvar ActiveHoldToLoot
    wait 1000
    
    while findtype 39889|3712|29833|45298|15296|20006|31041|30997|39891|31178|31190|31186|31019|31055|31025|31035|31053|39912|31027|31191|31001|31029|31182|37181|31172|31049|31010|31128|30994|30990|31011|0997|31169|31051|30993|20010|30996|39909|31002|31038|20014|39916|7107|30991|31014|31007|30998|31176|20012|31142|31000|31005|31023|31043|51098|31033|30999|20008|39917|39898|31037|31008|39918|31021|31184|31047|1055|31188|31031|30989|30988|7109|30995|20016|1043|31009|31130|31180|30992|31180|31003|31006|31012|4026|31004|31045|31017|31141|20006|31015|4026|5905|4025|17686|3891|39917|39891|3821|4225|2539|17617|17619|2426|7708|24434|43206|29363|43166|22336|29348|17087|3985|8826|3827|29030|3836|5981|4248|5359|3839|3838|3843|2597|29036|48407|3834|3865|3859|3885|3856|3878|3877|3873|3861|3862|576|5123|7177|7027|3920|5131|5179|5075|3980|5060|5076|5042|10245|3938|3913|7169|3909|5063|5089|3981|7170|7033|3976|3762|5040|5103|5117|7181|7029|3568|6264|3742|5139|6263|7026|5125|3740|5121|3973|3974|5204|5105|5185|5078|5115|7175|5059|7034|3713|3915|5112|5070|5049|5119|5205|5046|3962|3934|7035|3911|7179|5106|5143|3573|3719|5177|7610|5181|3917|5132|3963|7031|5207|5056|5085|3763|5129|5187|3721|3972|5138|3570|5101|5061|5074|5142|5182|5146|6265|5090|5203|5044|5144|3932|5201|5127|3572|7173|5135|3937|3571|22326|27611|9917|3821|5356|8455|5362|45315|8454|22187|5901|7163|3903|126863854|7981|7982|7983|7984|7985|7986|7987|7988|7989|7990|7991|7992|7993|7994|7995|7996|7997|7998|7999|8000|8001|8002|8003|8004|8005|8006|8007|8008|8009|8010|8011|8012|8013|8014|8015|8016|8017|8018|8019|8020|8021|8022|8023|8024|8025|8026|8027|8028|8029|8030|8031|8032|8033|8034|8035|8036|8037|8038|8039|8040|8041|8042|8033|8044|3854|2545 ActiveHoldToLoot as YourValuables
