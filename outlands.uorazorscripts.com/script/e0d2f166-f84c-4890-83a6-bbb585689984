                            say "[AspectSpellbook Poison"
                            getlabel backpack ping
                        endif
                    elseif "Combat Shadow Aspect Spellbook" = 1
                        if "shadow" in righthanddesc
                            //donothing
                        else 
                            say "[AspectSpellbook Shadow"
                            getlabel backpack ping
                        endif
                    elseif "Combat Temporal Aspect Spellbook" = 1
                        if "temporal" in righthanddesc
                            //donothing
                        else 
                            say "[AspectSpellbook Temporal"
                            getlabel backpack ping
                        endif
