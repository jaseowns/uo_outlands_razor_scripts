# Fishing Spot Helper by Jaseowns
# UO Outlands

@setvar! myFishingNet 0
if not targetexists 
    if findtype 3530 backpack 1763 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2219 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2207 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2425 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2213 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2413 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 2419 as item
        @setvar! myFishingNet item
    elseif findtype 3530 backpack 0 as item
        @setvar! myFishingNet item
    endif
endif


if myFishingNet != 0
    dclick myFishingNet
    wft 500
    if targetexists 
        hotkey "Target Self"
    endif
    getlabel backpack jaseowns_PingCheck
    if insysmsg "anything nearby that requires a fishing net"
        overhead "No fish!" 34
    else
        wait 500
        replay
    endif
endif