                    @setvar! PotionStockCheck 6
                else 
                    @setvar! PotionType 3846
                    @setvar! KegColour 1109
                    @setvar! PotionAmounttoFill ResistPotionAmount
                    @setvar! PotionStockCheck 6
                endif
            elseif PotionStockCheck = 6 
