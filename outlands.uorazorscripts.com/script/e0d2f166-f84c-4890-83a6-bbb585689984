                        pause 500
                        lift "BapTmapGoldSack"
                        getlabel backpack ping
                        while casting 
                            //donothing
                        endwhile
                        getlabel backpack ping
                        pause 350
                        if findtype 3948 ground 0 -1 2 as bluegate
                            say "[moongate"
                            waitforgump 3899019871 1600
                            gumpresponse 2
                            getlabel backpack ping
                            pause 350
                        endif
                        if findtype "bank deposit safe" ground -1 -1 2 as bankdepot
                            drop 0
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            dclick "BapTmapGoldSack"
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            while findtype "gold coin" "BapTmapGoldSack" as sackgoldbap
                                drop backpack
                                lift sackgoldbap 60000
                                drop bankdepot -1 -1 0
                                while queued
                                    //donothing
                                endwhile
                                getlabel backpack ping
                            endwhile
                            drop backpack
                            lift "BapTmapGoldSack"
                            drop backpack
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                        else 
                            drop 0
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            overhead "<Gold Sack Here>" 88 "BapTmapGoldSack"
                        endif
                        warmode on
                        script "Bapeths One Tile Item Dump & Restock"
                        warmode off
                        stop
                    endif
                endif    
                    
                if "Inn" = 1
                    say "[Gate Inn"
                    getlabel backpack ping
                    if insysmsg "Players may only travel to or from a waypost"
                        overhead "I cannot open a gate here..."
                        stop
                    elseif insysmsg "Magical travel is not allowed in this location"
                        overhead "I cannot open a gate here..."
                        stop
                    else
                        pause 500
                        lift "BapTmapGoldSack"
                        getlabel backpack ping
                        while casting 
                            //donothing
                        endwhile
                        getlabel backpack ping
                        pause 350
                        if findtype 3948 ground 0 -1 2 as bluegate
                            say "[moongate"
                            waitforgump 3899019871 1600
                            gumpresponse 2
                            getlabel backpack ping
                            pause 350
                        endif
                        say 'Room' 88
                        waitforgump 2393832411 500
                        if ingump "Enter Your Room" 2393832411
                            gumpresponse 4
                        elseif ingump "Rent This Room" 2393832411
                            gumpresponse 5
                            waitforgump 2393832411 500
                            gumpresponse 100
                        endif
                        pause 350
                        if findtype "bank deposit safe" ground -1 -1 2 as bankdepot
                            drop 0
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            dclick "BapTmapGoldSack"
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            while findtype "gold coin" "BapTmapGoldSack" as sackgoldbap
                                drop backpack
                                lift sackgoldbap 60000
                                drop bankdepot -1 -1 0
                                while queued
                                    //donothing
                                endwhile
                                getlabel backpack ping
                            endwhile
                            drop backpack
                            lift "BapTmapGoldSack"
                            drop backpack
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                        else 
                            drop 0
                            while queued
                                //donothing
                            endwhile
                            getlabel backpack ping
                            overhead "<Gold Sack Here>" 88 "BapTmapGoldSack"
                        endif
                        warmode on
                        script "Bapeths One Tile Item Dump & Restock"
                        warmode off
                        stop
                    endif                    
                endif
            endif
            if not find "BapTmapGoldSack" ground -1 -1 1
                overhead "Time to move on..." 88
                script "Bapeths One Tile Item Dump & Restock"
                stop
            endif
        endif
    endif
endif
