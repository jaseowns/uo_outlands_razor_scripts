# Automation by Jaseowns
## Script: Check Crook and Instrument
## Created by: abianche#0
#############################################

# Made by @abianche on discord (Artemis).

@setvar! crookFound 0
@setvar! instrumentFound 0

while findtype 3713 backpack as Crook
    getlabel Crook desc
    if "activated" in desc
        overhead "Sheperd's crook found!" 55
        # overhead "Sheperd's crook found" 55 Crook
        sysmsg desc 55
        @setvar! crookFound 1
        break
     endif
endwhile

if crookFound = 0
    overhead "Sheperd's crook not found!" 34
endif

while findtype 20008|3762|10245|3763|3740|20006|3742|20014|20012 backpack as Instrument
    getlabel Instrument desc
    if "exceedingly melodious" in desc or "supremely melodious" in desc or "greater" in desc
        overhead "Instrument found!" 55
        # overhead "Instrument found" 55 Instrument
        sysmsg desc 55
        @setvar! instrumentFound 1
        break
    endif
endwhile

if instrumentFound = 0
    overhead "Instrument not found!" 34
endif